{
  "uid": "api-gateway",
  "title": "API Gateway Rate Limiter",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(api_gateway_http_requests_total[1m])) by (status)",
          "legendFormat": "status {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Rate-limit rejection rate",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(api_gateway_rate_limit_rejections_total[1m]))",
          "legendFormat": "rejections/sec"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 latency",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(api_gateway_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "p99 latency",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(api_gateway_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests by gateway instance",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(api_gateway_http_requests_total[1m])) by (instance)",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "In-flight requests",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(api_gateway_http_in_flight_requests) by (instance)",
          "legendFormat": "{{instance}}"
        }
      ]
    }
  ]
}